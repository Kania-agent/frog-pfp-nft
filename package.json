{
  "name": "frog-pfp-nft",
  "version": "1.0.0",
  "description": "Frog PFP - 100-piece animated pixel art frog NFT collection",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:localhost": "hardhat run scripts/deploy.js --network localhost",
